{
  "name": "dinkyproxy",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "pnpm --filter ./apps/ui dev",
    "build": "pnpm clean && pnpm --filter ./apps/ui build && pnpm --filter ./apps/ui tauri:build && node scripts/collect-builds.js",
    "lint": "turbo run lint",
    "clean": "rimraf .turbo/cache dist apps/ui/dist apps/ui/src-tauri/target",
    "test:unit": "cargo test --manifest-path apps/ui/src-tauri/Cargo.toml",
    "test:e2e": "pnpm --filter dinkyproxy-ui exec playwright test",
    "test:e2e:ui": "pnpm test:e2e --ui",
    "test:e2e:update": "pnpm test:e2e --update-snapshots",
    "release": "bash scripts/release.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "turbo": "^2.10.0"
  }
}
