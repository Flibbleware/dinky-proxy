{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist",
      "!build",
      "!src-tauri",
      "!src/routeTree.gen.ts",
      "!.turbo",
      "!.vite",
      "!.tanstack",
      "!**/*.svg",
      "!**/*.tsbuildinfo",
      "!test-results",
      "!**/playwright-report"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noNonNullAssertion": "error",
        "useSelfClosingElements": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "error"
      },
      "complexity": {
        "noUselessFragments": "error"
      },
      "correctness": {
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "options": {
            "attributes": ["className"],
            "functions": ["clsx", "cn", "twMerge", "cva"]
          }
        }
      }
    }
  }
}
